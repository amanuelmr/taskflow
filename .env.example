# Copy to .env and fill in real values. Never commit .env.

# Django secret keys — generate one per service:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY_USER=change-me-user
SECRET_KEY_TASK=change-me-task
SECRET_KEY_NOTIFICATION=change-me-notification

DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Databases (one postgres container per service; shared credentials for dev)
DATABASE_USER=postgres
DATABASE_PASSWORD=change-me-db-password

# RabbitMQ
RABBITMQ_USER=taskapp
RABBITMQ_PASSWORD=change-me-rabbitmq-password

# JWT RS256 keys — generate with:
#   mkdir -p secrets
#   openssl genrsa -out secrets/jwt_private.pem 2048
#   openssl rsa -in secrets/jwt_private.pem -pubout -out secrets/jwt_public.pem
# (paths are inside the containers; docker-compose mounts ./secrets)
JWT_PRIVATE_KEY_PATH=/keys/jwt_private.pem
JWT_PUBLIC_KEY_PATH=/keys/jwt_public.pem

# Email (user_service). Leave EMAIL_HOST_PASSWORD empty to use the console
# backend in dev (emails printed to the service log).
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=no-reply@example.com

# CORS (comma-separated origins allowed to call the APIs from a browser)
CORS_ALLOWED_ORIGINS=http://localhost:3000
